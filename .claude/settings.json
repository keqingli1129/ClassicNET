{
  "mcpServers": {
    "mssql": {
      "command": "uvx",
      "args": ["--from", "microsoft-sql-server-mcp", "mssql_mcp_server"],
      "env": {
        "MSSQL_SERVER": "localhost\\SQLEXPRESS",
        "MSSQL_DATABASE": "MVCNet",
        "MSSQL_WINDOWS_AUTH": "true",
        "MSSQL_ENCRYPT": "no",
        "MSSQL_TRUST_SERVER_CERTIFICATE": "yes",
        "PYTHONUNBUFFERED": "1",
        "LOG_LEVEL": "ERROR"
      }
    }
  }
}