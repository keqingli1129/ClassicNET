                        </div>
                    </div>

                    <div class="mb-3 row">
                        @Html.LabelFor(model => model.ShipCountry, htmlAttributes: new { @class = "col-md-3 col-form-label" })
                        <div class="col-md-9">
                            @Html.EditorFor(model => model.ShipCountry, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ShipCountry, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-9 offset-md-3">
                            <input type="submit" value="Create" class="btn btn-primary me-2" />
                            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-outline-secondary" })
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
