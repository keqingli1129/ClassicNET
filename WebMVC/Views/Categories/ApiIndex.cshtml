@using System.Linq
@model IEnumerable<WebMVC.Models.Category>

@{
    ViewBag.Title = "Categories from API";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Categories from API</h2>
    @Html.ActionLink("Back to Categories", "Index", null, new { @class = "btn btn-outline-secondary" })
</div>

@if (ViewBag.ApiError != null)
{
    <div class="alert alert-danger" role="alert">
        @ViewBag.ApiError
    </div>
}
else if (!Model.Any())
{
    <div class="alert alert-info" role="alert">
        No categories were returned by the API.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.CategoryName)</th>
                            <th>@Html.DisplayNameFor(model => model.Description)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.CategoryName)</td>
                                <td>@Html.DisplayFor(modelItem => item.Description)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav aria-label="Categories from API pagination" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    @Html.ActionLink("Previous", "ApiIndex", new { page = currentPage - 1 }, new { @class = "page-link" })
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        @Html.ActionLink(i.ToString(), "ApiIndex", new { page = i }, new { @class = "page-link" })
                    </li>
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    @Html.ActionLink("Next", "ApiIndex", new { page = currentPage + 1 }, new { @class = "page-link" })
                </li>
            </ul>
        </nav>
    }
}
